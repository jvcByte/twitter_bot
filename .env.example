# Twitter/X session cookies (required)
# Export from your browser using the Cookie-Editor extension, paste the JSON array here
TWITTER_COOKIES=

# Twitter credentials (used as fallback display only)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password

# Optional: filter tweets to a single category
# Options: world, tech, cybersecurity, business, environment, science, space, health, africa
# Leave empty to tweet from all categories
CATEGORY=

# Tuning (all optional — defaults shown)
POLL_INTERVAL_MINUTES=5      # how often to check all 290 feeds
MAX_ARTICLE_AGE_HOURS=2      # ignore articles older than this
TWEET_DELAY_SECONDS=90       # gap between consecutive tweets
MAX_TWEETS_PER_RUN=5         # max tweets per run (0 = unlimited)
