# Your Twitter/X login credentials
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password

# Hugging Face API token (huggingface.co/settings/tokens)
# Make sure "Make calls to the serverless Inference API" permission is enabled
HUGGINGFACE_API_KEY=hf_your_token_here

# Optional: force a specific content type instead of random
# Options: random, template, rss, ai
POST_MODE=random
